---
import Default from '@astrojs/starlight/components/SocialIcons.astro';
---

<div class="custom-social-icons">
	<a href="https://live.turtletracer.com" target="_blank" rel="noopener noreferrer" class="social-link live-link">
		<span class="label">TurtleTracer for Web</span>
		<span class="icon">
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" height="20" width="20" aria-hidden="true">
				<path d="M18 13v6a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
				<polyline points="15 3 21 3 21 9" />
				<line x1="10" y1="14" x2="21" y2="3" />
			</svg>
		</span>
	</a>
	<a href="https://discord.gg/chHSzS4ewF" target="_blank" rel="noopener noreferrer" class="social-link">
		<span class="icon">
			<svg viewBox="0 0 16 16" fill="currentColor" height="20" width="20" aria-hidden="true">
				<path d="M13.545 2.907a13.227 13.227 0 0 0-3.257-1.011.05.05 0 0 0-.052.025c-.141.25-.297.577-.406.833a12.19 12.19 0 0 0-3.658 0 8.258 8.258 0 0 0-.412-.833.051.051 0 0 0-.052-.025c-1.125.194-2.22.534-3.257 1.011a.041.041 0 0 0-.021.018C.356 6.024-.213 9.047.066 12.032c.001.014.01.028.021.037a13.276 13.276 0 0 0 3.995 2.02.05.05 0 0 0 .056-.019c.308-.42.582-.863.818-1.329a.05.05 0 0 0-.01-.059.051.051 0 0 0-.018-.011 8.875 8.875 0 0 1-1.248-.595.05.05 0 0 1-.02-.066.051.051 0 0 1 .015-.019c.084-.063.168-.129.248-.195a.05.05 0 0 1 .051-.007c2.619 1.196 5.454 1.196 8.041 0a.052.052 0 0 1 .053.007c.08.066.164.132.248.195a.051.051 0 0 1-.004.085 8.254 8.254 0 0 1-1.249.594.05.05 0 0 0-.03.03.052.052 0 0 0 .003.041c.24.465.515.909.817 1.329a.05.05 0 0 0 .056.019 13.235 13.235 0 0 0 4.001-2.02.049.049 0 0 0 .021-.037c.334-3.451-.559-6.449-2.366-9.106a.034.034 0 0 0-.02-.019Zm-8.198 7.307c-.789 0-1.438-.724-1.438-1.612 0-.889.637-1.613 1.438-1.613.807 0 1.45.73 1.438 1.613 0 .888-.637 1.612-1.438 1.612Zm5.316 0c-.788 0-1.438-.724-1.438-1.612 0-.889.637-1.613 1.438-1.613.807 0 1.451.73 1.438 1.613 0 .888-.631 1.612-1.438 1.612Z"></path>
			</svg>
		</span>
		<span class="label">Discord</span>
	</a>
</div>

<style>
	.custom-social-icons {
		display: flex;
		gap: 1rem;
		align-items: center;
	}

	.social-link {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		text-decoration: none;
		color: var(--sl-color-text-accent);
		transition: color 0.2s, background-color 0.2s, transform 0.2s;
	}

	.social-link:hover {
		color: var(--sl-color-white);
	}

	.social-link.live-link {
		padding: 0.5rem 0.8rem;
		border-radius: 999px;
		background: linear-gradient(135deg, var(--sl-color-primary), var(--sl-color-accent));
		color: var(--sl-color-white);
		box-shadow: 0 12px 24px rgba(0, 0, 0, 0.12);
		border: 1px solid rgba(255, 255, 255, 0.2);
	}

	.social-link.live-link:hover {
		transform: translateY(-1px);
		background: linear-gradient(135deg, var(--sl-color-primary-strong), var(--sl-color-accent));
		border-color: rgba(255, 255, 255, 1);
	}

	.social-link.live-link .label {
		max-width: 200px;
		opacity: 1;
	}

	.icon {
		display: flex;
		align-items: center;
	}

	.label {
		max-width: 0;
		overflow: hidden;
		white-space: nowrap;
		opacity: 0;
		transition: max-width 0.3s ease, opacity 0.3s ease;
		font-weight: 500;
	}

	/* Show text on hover */
	.social-link:hover .label {
		max-width: 200px;
		opacity: 1;
	}

	/* Mobile styles: ensure icons are always visible but label behavior might differ */
	@media (max-width: 640px) {
		.custom-social-icons {
			gap: 0.5rem;
		}

		/* On mobile, maybe keep the hover effect or just hide labels to save space?
		   The request said "keep it mobile friendly". Expanding on click/tap might be annoying or break layout.
		   Let's keep the hover behavior which on mobile usually translates to tap.
		   But to be safe and avoid layout shift issues on small screens, we might want to be careful.
		   For now, I'll keep the same behavior as it is "smooth animation".
		*/
	}
</style>
